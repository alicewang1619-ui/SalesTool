# 项目知识库 后端环境变量（均有合理本地默认，可不配）
PORT=8787
# 数据目录（SQLite + 备份）。默认 server/data
# ZKB_DATA_DIR=/absolute/path/to/data
# 本地 Ollama 端点
OLLAMA_BASE_URL=http://localhost:11434
# 模型常驻内存时长：5m=保持热(默认) / 30s=省内存 / 0=用完即卸载 / -1=永久常驻
ZKB_OLLAMA_KEEP_ALIVE=5m
# 默认模型（也可在设置页改）
ZKB_CHAT_MODEL=llama3.1:8b
ZKB_EMBED_MODEL=nomic-embed-text
# 限流（每分钟）
ZKB_AI_RATE_LIMIT=30
ZKB_WRITE_RATE_LIMIT=120
# 日志级别 debug|info|warn|error
ZKB_LOG_LEVEL=info
