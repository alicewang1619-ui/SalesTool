    "key_decisions_made":  [
                               {
                                   "id":  "D-1",
                                   "stage":  "prd",
                                   "decision":  "产品定位为智能销售接待与客户洞察 Agent，不是单纯询盘管理工具。",
                                   "rationale":  "用户需要统一收口、在线接待、引导提问、客户调研、销售分发、反馈追踪、报表和再营销闭环。"
                               },
                               {
                                   "id":  "D-2",
                                   "stage":  "prd",
                                   "decision":  "V1 暂不接 Facebook / LinkedIn 官方 API 或个人后台，不做未授权抓取。",
                                   "rationale":  "用户在了解授权/API 限制后确认先按原 V1 做。"
                               },
                               {
                                   "id":  "D-3",
                                   "stage":  "design-I",
                                   "decision":  "第一版端形态为 PC 管理后台 + 手机销售反馈卡片。",
                                   "rationale":  "运营和管理者需要处理列表、报表、配置；销售只需要 10-30 秒完成轻量反馈。"
                               },
                               {
                                   "id":  "D-4",
                                   "stage":  "design-I",
                                   "decision":  "后台信息架构采用左侧导航、首页工作台和 6 个主分区。",
                                   "rationale":  "覆盖工作台、线索池、客户池、报表中心、再营销待办、系统配置。"
                               },
                               {
                                   "id":  "D-5",
                                   "stage":  "design-I",
                                   "decision":  "角色权限分为管理员、营销/运营、销售三层。",
                                   "rationale":  "销售不进入复杂后台，只通过手机反馈卡片提交状态、判断和备注。"
                               },
                               {
                                   "id":  "D-6",
                                   "stage":  "design-I",
                                   "decision":  "视觉风格为浅色医疗科技 SaaS，主色使用蓝紫色，不使用青蓝色。",
                                   "rationale":  "用户明确要求不要青蓝色，用蓝紫色，其他方向正确。"
                               },
                               {
                                   "id":  "D-7",
                                   "stage":  "design-I",
                                   "decision":  "V1 数据集成聚焦官网聊天、官网后台、邮箱、展会名片导入和销售反馈闭环。",
                                   "rationale":  "保证第一版合规可落地，并把 Facebook / LinkedIn 后置。"
                               },
                               {
                                   "id":  "D-8",
                                   "stage":  "design-I",
                                   "decision":  "技术架构采用 React + Ant Design Pro、Python FastAPI、Postgres、Redis + Celery/RQ、Docker Compose 的模块化单体。",
                                   "rationale":  "优先快速落地 MVP，同时保留任务队列、AI 编排、报表聚合和未来拆服务边界。"
                               },
                               {
                                   "id":  "D-9",
                                   "stage":  "design-I",
                                   "decision":  "官网不单独作为 KPI 系统，而是在销售增长系统内做官网渠道 KPI 归因。",
                                   "rationale":  "用户不确定网站是否可以做 KPI，因此将 KPI 口径放在系统的渠道归因维度。"
                               },
                               {
